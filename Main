        { question: '哪吒是三头六臂，那人是？', answer: '人就是人', keywords: ['人'] },
        { question: '恐龙："剪刀。"  上帝："石头！"  恐龙："（）"！', answer: '布！', keywords: ['布'] },
        { question: '你在沙漠里迷失了方向，只有两瓶水，一瓶毒药一瓶尿，你选什么', answer: '两杯水', keywords: ['水'] },
        { question: '如何表示恍然大悟', answer: '我去！不早说', keywords: ['不早说'] },
        { question: '小明踢球把人踢伤了，为什么家属没有赔钱', answer: '踢到自己老冯身上了', keywords: ['爸','妈','父母','家长','浮木','老冯','爹','娘'] }
      ];

      const AUTHOR = '監視していません';
      const CREATOR_TEXT = '由 あなたを監視していません 制作';

      // ---------- 本地存储 ----------
      function loadFromStorage(key, fallback) {
        try {
          const raw = localStorage.getItem(key);
          return raw ? JSON.parse(raw) : fallback;
        } catch (e) {
          return fallback;
        }
      }

      function saveToStorage(key, data) {
        try {
          localStorage.setItem(key, JSON.stringify(data));
        } catch (e) {}
      }

      let pendingQuestions = loadFromStorage('wq_pending', []);
      let approvedQuestions = loadFromStorage('wq_approved', []);

      function savePending() { saveToStorage('wq_pending', pendingQuestions); }
      function saveApproved() { saveToStorage('wq_approved', approvedQuestions); }

      // ---------- 动态题库 ----------
      function getTotalQuestions() {
        return BASE_QUESTIONS.length + approvedQuestions.length;
      }

      function getQuestionByIndex(index) {
        if (index < BASE_QUESTIONS.length) {
          const q = BASE_QUESTIONS[index];
          return {
            question: q.question,
            answer: q.answer,
            keywords: q.keywords,
            author: AUTHOR
          };
        } else {
          const custom = approvedQuestions[index - BASE_QUESTIONS.length];
          return {
            question: custom.question,
            answer: custom.answer,
            keywords: custom.keywords || [],
            author: custom.author || '匿名'
          };
        }
      }

      function getPrevAnswerForIndex(index) {
        if (index === 0) return '/';
        const prev = getQuestionByIndex(index - 1);
        return prev ? prev.answer : '/';
      }

      // ---------- 工具函数 ----------
      function normalizeInput(str) {
        return (str || '').trim().toLowerCase();
      }

      function checkKeywords(input, keywords) {
        const norm = normalizeInput(input);
        if (!norm) return false;
        return keywords.some(kw => norm.includes(kw.toLowerCase()));
      }

      function escapeHTML(str) {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      }

      // ---------- 纸屑 ----------
      function spawnConfetti() {
        const container = document.getElementById('confettiContainer');
        const colors = ['#e85d3a','#f0a830','#3a8c5c','#f7c948','#e05b7b','#5b9bd5','#a855f7','#f97316','#06b6d4','#ec4899'];
        const frag = document.createDocumentFragment();
        for (let i = 0; i < 50; i++) {
          const piece = document.createElement('div');
          piece.className = 'confetti-piece';
          piece.style.left = Math.random() * 100 + '%';
          piece.style.top = -(Math.random() * 60 + 10) + 'px';
          piece.style.width = (Math.random() * 10 + 6) + 'px';
          piece.style.height = (Math.random() * 10 + 6) + 'px';
          piece.style.background = colors[Math.floor(Math.random() * colors.length)];
          piece.style.animationDuration = (Math.random() * 2 + 2) + 's';
          piece.style.animationDelay = Math.random() * 0.6 + 's';
          frag.appendChild(piece);
        }
        container.appendChild(frag);
        setTimeout(() => { container.innerHTML = ''; }, 3500);
      }

      // ---------- 视图状态 ----------
      let currentView = 'game'; // 'game' | 'create' | 'review'
      let currentIndex = 0;
      let isLocked = false;
      let hasAnsweredCurrent = false;

      const appContainer = document.getElementById('appContainer');

      // ---------- 渲染函数 ----------
      function renderGame() {
        currentView = 'game';
        const total = getTotalQuestions();
        if (currentIndex >= total) currentIndex = total - 1;
        if (currentIndex < 0) currentIndex = 0;

        const qData = getQuestionByIndex(currentIndex);
        const prevAns = getPrevAnswerForIndex(currentIndex);
        const isFirst = currentIndex === 0;
        const displayNum = currentIndex + 1;
        const progressPercent = total > 0 ? Math.round((currentIndex / total) * 100) : 0;

        const prevAnsHTML = (isFirst || prevAns === '/')
          ? '<span class="prev-answer-content slash">/</span>'
          : '<span class="prev-answer-content">' + escapeHTML(prevAns) + '</span>';

        const html = `
          <div class="card" id="mainCard">
            <div class="header">
              <div class="title"><span class="emoji-bulb">💡</span> 我去不早说！</div>
              <div class="creator-line">${escapeHTML(CREATOR_TEXT)}</div>
              <div class="subtitle-row">
                <span class="author-tag">出题人：${escapeHTML(qData.author)}</span>
                <span class="id-tag">#${displayNum}</span>
              </div>
            </div>
            <div class="prev-answer-area">
              <div class="prev-answer-label">📌 上一题答案</div>
              ${prevAnsHTML}
            </div>
            <div class="question-block" id="questionBlock">
              <p class="question-text">${escapeHTML(qData.question)}</p>
            </div>
            <div class="input-group" id="inputGroup">
              <input type="text" id="answerInput" placeholder="输入你的答案..." autocomplete="off" maxlength="200">
              <button class="btn btn-submit" id="btnSubmit">提交</button>
            </div>
            <button class="btn btn-next" id="btnNext">下一题 →</button>
            <div class="feedback" id="feedback"></div>
            <div class="progress-wrap">
              <div class="progress-bar-outer"><div class="progress-bar-inner" id="progressBar" style="width:${progressPercent}%;"></div></div>
              <span class="progress-text">${displayNum} / ${total}</span>
            </div>
            <div class="action-buttons">
              <button class="btn btn-outline" id="btnCreateView">✚ 自创题目</button>
              <button class="btn btn-outline" id="btnReviewView">📋 审核题目</button>
            </div>
          </div>
        `;

        appContainer.innerHTML = html;
        hasAnsweredCurrent = false;
        isLocked = false;

        const inputEl = document.getElementById('answerInput');
        const btnSubmit = document.getElementById('btnSubmit');
        const btnNext = document.getElementById('btnNext');
        const feedbackEl = document.getElementById('feedback');
        const mainCard = document.getElementById('mainCard');

        setTimeout(() => { if (inputEl && !isLocked) inputEl.focus(); }, 300);

        function handleSubmit() {
          if (isLocked || hasAnsweredCurrent) return;
          const trimmed = inputEl.value.trim();
          if (!trimmed) {
            feedbackEl.innerHTML = '<span style="color:#d4534a;">⚠️ 请输入答案再提交哦~</span>';
            inputEl.classList.add('error-flash');
            setTimeout(() => inputEl.classList.remove('error-flash'), 500);
            inputEl.focus();
            return;
          }
          const correct = checkKeywords(trimmed, qData.keywords);
          if (correct) {
            isLocked = true;
            hasAnsweredCurrent = true;
            feedbackEl.className = 'feedback correct';
            feedbackEl.innerHTML = '✅ 回答正确！<span class="answer-reveal">答案：' + escapeHTML(qData.answer) + '</span>';
            inputEl.classList.add('success-flash');
            btnSubmit.disabled = true;
            inputEl.disabled = true;
            mainCard.classList.add('pop-correct');
            if (currentIndex < total - 1) {
              btnNext.classList.add('show');
              btnNext.textContent = '下一题 →';
              btnNext.focus();
            } else {
              btnNext.classList.add('show');
              btnNext.textContent = '🎉 查看回顾';
              btnNext.focus();
            }
            spawnConfetti();
          } else {
            feedbackEl.className = 'feedback wrong';
            feedbackEl.innerHTML = '🤔 再想想~ 关键词不太对哦';
            inputEl.classList.add('error-flash');
            mainCard.classList.add('shake');
            setTimeout(() => {
              inputEl.classList.remove('error-flash');
              mainCard.classList.remove('shake');
            }, 500);
            inputEl.select();
            inputEl.focus();
          }
        }

        function handleNext() {
          if (!hasAnsweredCurrent) return;
          if (currentIndex < total - 1) {
            currentIndex++;
            renderGame();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          } else {
            renderFinish();
            window.scrollTo({ top: 0, behavior: 'smooth' });
            spawnConfetti();
            setTimeout(spawnConfetti, 800);
          }
        }

        btnSubmit.addEventListener('click', handleSubmit);
        btnNext.addEventListener('click', handleNext);
        inputEl.addEventListener('keydown', function(e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            if (hasAnsweredCurrent && btnNext.classList.contains('show')) {
              handleNext();
            } else if (!hasAnsweredCurrent && !isLocked) {
              handleSubmit();
            }
          }
        });

        document.getElementById('btnCreateView').addEventListener('click', () => {
          renderCreateForm();
        });
        document.getElementById('btnReviewView').addEventListener('click', () => {
          renderReviewPanel();
        });
      }

      function renderFinish() {
        currentView = 'game';
        const allQuestions = [];
        for (let i = 0; i < BASE_QUESTIONS.length; i++) {
          allQuestions.push({ ...BASE_QUESTIONS[i], author: AUTHOR });
        }
        approvedQuestions.forEach(q => allQuestions.push(q));

        let listHTML = '';
        allQuestions.forEach((q, idx) => {
          listHTML += `<div class="review-item-mini"><strong>#${idx+1}</strong> ${escapeHTML(q.question)}<br><span style="color:#3a8c5c;">💡 ${escapeHTML(q.answer)}</span></div>`;
        });

        const html = `
          <div class="card finish-screen">
            <span class="trophy">🏆</span>
            <h2>恭喜通关！</h2>
            <p>你已完成全部 <strong>${allQuestions.length}</strong> 道题目</p>
            <div class="review-list">${listHTML}</div>
            <button class="btn btn-submit" id="btnRestart">🔄 再来一次</button>
            <div class="action-buttons" style="margin-top:12px;">
              <button class="btn btn-outline" id="btnCreateView2">✚ 自创题目</button>
              <button class="btn btn-outline" id="btnReviewView2">📋 审核题目</button>
            </div>
          </div>
        `;
        appContainer.innerHTML = html;
        document.getElementById('btnRestart').addEventListener('click', () => {
          currentIndex = 0;
          hasAnsweredCurrent = false;
          isLocked = false;
          renderGame();
        });
        document.getElementById('btnCreateView2').addEventListener('click', renderCreateForm);
        document.getElementById('btnReviewView2').addEventListener('click', renderReviewPanel);
      }

      function renderCreateForm() {
        currentView = 'create';
        const html = `
          <div class="form-panel">
            <h3>✚ 自创题目</h3>
            <div class="form-group">
              <label>题目</label>
              <input type="text" id="newQuestion" placeholder="输入你的问题" maxlength="200">
            </div>
            <div class="form-group">
              <label>答案</label>
              <input type="text" id="newAnswer" placeholder="正确答案" maxlength="200">
            </div>
            <div class="form-group">
              <label>关键词（用逗号分隔）</label>
              <input type="text" id="newKeywords" placeholder="例如：关键词1,关键词2" maxlength="200">
            </div>
            <div class="form-group">
              <label>出题人</label>
              <input type="text" id="newAuthor" placeholder="你的名字（可选）" maxlength="50">
            </div>
            <button class="btn btn-submit" id="btnSubmitNew">提交审核</button>
            <div style="text-align:center;margin-top:10px;">
              <span class="back-link" id="backToGame">← 返回游戏</span>
            </div>
            <div class="feedback" id="createFeedback" style="margin-top:8px;"></div>
          </div>
        `;
        appContainer.innerHTML = html;

        document.getElementById('btnSubmitNew').addEventListener('click', () => {
          const q = document.getElementById('newQuestion').value.trim();
          const a = document.getElementById('newAnswer').value.trim();
          const kwRaw = document.getElementById('newKeywords').value.trim();
          const author = document.getElementById('newAuthor').value.trim() || '匿名';
          if (!q || !a || !kwRaw) {
            document.getElementById('createFeedback').innerHTML = '<span style="color:#d4534a;">请填写题目、答案和关键词</span>';
            return;
          }
          const keywords = kwRaw.split(',').map(k => k.trim()).filter(k => k);
          if (keywords.length === 0) {
            document.getElementById('createFeedback').innerHTML = '<span style="color:#d4534a;">请至少输入一个关键词</span>';
            return;
          }
          pendingQuestions.push({ question: q, answer: a, keywords, author });
          savePending();
          document.getElementById('createFeedback').innerHTML = '<span style="color:#3a8c5c;">✅ 已提交审核！</span>';
          // 清空表单
          document.getElementById('newQuestion').value = '';
          document.getElementById('newAnswer').value = '';
          document.getElementById('newKeywords').value = '';
          document.getElementById('newAuthor').value = '';
        });

        document.getElementById('backToGame').addEventListener('click', renderGame);
      }

      function renderReviewPanel() {
        currentView = 'review';
        let listHTML = '';
        if (pendingQuestions.length === 0) {
          listHTML = '<div class="empty-state">📭 暂无待审核题目</div>';
        } else {
          pendingQuestions.forEach((item, idx) => {
            listHTML += `
              <div class="review-item">
                <div class="r-question">❓ ${escapeHTML(item.question)}</div>
                <div class="r-answer">💡 ${escapeHTML(item.answer)}</div>
                <div class="r-keywords">🏷️ 关键词：${item.keywords.map(k => escapeHTML(k)).join('、')}</div>
                <div class="r-keywords">👤 出题人：${escapeHTML(item.author || '匿名')}</div>
                <div class="review-actions">
                  <button class="btn btn-approve" data-idx="${idx}">✅ 通行</button>
                  <button class="btn btn-reject" data-idx="${idx}">❌ 下架</button>
                </div>
              </div>
            `;
          });
        }

        const html = `
          <div class="review-panel">
            <h3>📋 审核题目（待审核：${pendingQuestions.length}）</h3>
            ${listHTML}
            <div style="text-align:center;margin-top:14px;">
              <span class="back-link" id="backToGame2">← 返回游戏</span>
            </div>
          </div>
        `;
        appContainer.innerHTML = html;

        // 绑定通行/下架
        document.querySelectorAll('.btn-approve').forEach(btn => {
          btn.addEventListener('click', function() {
            const idx = parseInt(this.getAttribute('data-idx'));
            if (isNaN(idx) || idx < 0 || idx >= pendingQuestions.length) return;
            const approved = pendingQuestions.splice(idx, 1)[0];
            approvedQuestions.push(approved);
            savePending();
            saveApproved();
            renderReviewPanel();
            // 如果当前在游戏视图，刷新进度（无操作）
          });
        });

        document.querySelectorAll('.btn-reject').forEach(btn => {
          btn.addEventListener('click', function() {
            const idx = parseInt(this.getAttribute('data-idx'));
            if (isNaN(idx) || idx < 0 || idx >= pendingQuestions.length) return;
            pendingQuestions.splice(idx, 1);
            savePending();
            renderReviewPanel();
          });
        });

        document.getElementById('backToGame2').addEventListener('click', () => {
          // 回到游戏，保持当前题目索引，但总题数可能变了
          const total = getTotalQuestions();
          if (currentIndex >= total) currentIndex = Math.max(0, total - 1);
          renderGame();
        });
      }

      // ---------- 初始化 ----------
      function init() {
        currentIndex = 0;
        hasAnsweredCurrent = false;
        isLocked = false;
        renderGame();
      }

      init();
      console.log('💡 "我去不早说！" 已激活');
    })();
  </script>
</body>
</html>
